# --- Database (Neon Postgres) ---
DATABASE_URI=postgres://user:password@host/db?sslmode=require

# --- Payload ---
PAYLOAD_SECRET=replace-with-32-plus-char-random-string
NEXT_PUBLIC_SERVER_URL=https://uppereastsidehangout.com

# --- Resend transactional email ---
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@uppereastsidehangout.com
RESEND_FROM_NAME=Upper Eastside Hangout

# --- Vercel Blob (used via custom /api/upload route, NOT the storage plugin) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- First admin seeded on initial boot (used by Users collection beforeChange) ---
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
